# web-auth-bridge test credentials
#
# Copy this file to .env (or .env.tests) and fill in values for the sites
# you want to run e2e tests against.  Tests for sites without credentials
# are automatically skipped.
#
#   cp .env.example .env
#   pytest -m e2e                    # run all e2e tests with available creds
#   pytest -m "e2e and garmin"       # run only Garmin e2e tests
#
# .env is gitignored; never commit real credentials.

# --- Shared test tuning --------------------------------------------------

# Default to headless for CI.  Set to "false" to watch the browser drive
# the login flow (useful when credentials change or a site requires CAPTCHA).
WEB_AUTH_BRIDGE_E2E_HEADLESS=true

# Playwright browser channel for e2e tests.  Real Chrome is strongly
# preferred over bundled Chromium because WAFs (Cloudflare, Akamai, etc.)
# can often fingerprint the bundled build even with stealth patches.
WEB_AUTH_BRIDGE_E2E_CHANNEL=chrome

# --- Garmin Connect ------------------------------------------------------

GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- Rouvy ---------------------------------------------------------------

ROUVY_EMAIL=
ROUVY_PASSWORD=
