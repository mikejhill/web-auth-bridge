# Garmin Connect example configuration
# Copy to .env and fill in values to test different authentication modes.

# ── Credentials ──────────────────────────────────────────────────────────────
# When set, credentials are auto-entered by the browser (headless-compatible).
# When left blank, the browser opens visibly for manual entry.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# ── Browser Mode ─────────────────────────────────────────────────────────────
# true  = headless (no visible window, requires stored credentials above)
# false = headed   (visible window, supports manual login or stored credentials)
GARMIN_HEADLESS=true

# ── Credential Mode ──────────────────────────────────────────────────────────
# auto   = use GARMIN_EMAIL/GARMIN_PASSWORD from this file (default when set)
# manual = ignore stored credentials; user enters them in the visible browser
#          (forces headed mode regardless of GARMIN_HEADLESS)
# prompt = prompt for credentials interactively in the terminal
GARMIN_CREDENTIAL_MODE=auto

# ── Cache ────────────────────────────────────────────────────────────────────
# Directory for cached auth tokens. Defaults to ~/.config/garmin-connect/cache
# GARMIN_CACHE_DIR=~/.config/garmin-connect/cache
